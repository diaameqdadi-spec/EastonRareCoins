---
import BaseLayout from "../layouts/BaseLayout.astro";
import { newsItems } from "../data/site";
---

<BaseLayout
  title="Insights | Easton Rare Coin & Precious Metals"
  description="Market insight and educational content for clients selling gold, bullion, coins, jewelry, and paper currency."
>
  <section class="page-hero container narrow">
    <p class="eyebrow">Insights</p>
    <h1>Market context and seller education without the clutter.</h1>
    <p class="lede">
      The current site's "In the News" page mixes educational copy and market talking
      points. This version keeps the intent but presents it in a more editorial format.
    </p>
  </section>

  <section class="section">
    <div class="container stack">
      {newsItems.map((item) => (
        <article class="news-card">
          <p class="eyebrow">Seller insight</p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
