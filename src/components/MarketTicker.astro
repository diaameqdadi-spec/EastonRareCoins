---
const fallbackPrices = [
  { label: "Gold", value: "Loading..." },
  { label: "Silver", value: "Loading..." },
  { label: "Platinum", value: "Loading..." },
  { label: "Copper", value: "Loading..." }
];
---

<div
  class="market-ticker"
  data-market-ticker
  data-api-url="/data/metals.json"
>
  <div class="market-track">
    {fallbackPrices.map((item) => (
      <div class="market-item">
        <span>{item.label}</span>
        <strong>{item.value}</strong>
      </div>
    ))}
  </div>
</div>

<script>
    const root = document.querySelector("[data-market-ticker]");
    if (root) {
      const apiUrl = root.getAttribute("data-api-url");
      const track = root.querySelector(".market-track");

    const renderFallback = (message) => {
      if (!track) return;
      track.innerHTML = `
        <div class="market-item"><span>Gold</span><strong>${message}</strong></div>
        <div class="market-item"><span>Silver</span><strong>${message}</strong></div>
        <div class="market-item"><span>Platinum</span><strong>${message}</strong></div>
        <div class="market-item"><span>Copper</span><strong>${message}</strong></div>
      `;
    };

    if (!apiUrl || !track) {
      renderFallback("Unavailable");
    } else {
      fetch(apiUrl)
        .then(async (response) => {
          const data = await response.json();
          if (!response.ok || !Array.isArray(data?.prices)) {
            throw new Error(data?.message || "Ticker request failed");
          }
          return data.prices;
        })
        .then((prices) => {
          track.innerHTML = prices
            .map(({ label, price, changePct }) => {
              const formatted =
                typeof price === "number" && price > 0
                  ? new Intl.NumberFormat("en-US", {
                      style: "currency",
                      currency: "USD",
                      maximumFractionDigits: 2
                    }).format(value)
                  : "Unavailable";
              const delta =
                typeof changePct === "number"
                  ? `<em class="${changePct >= 0 ? "is-up" : "is-down"}">${changePct >= 0 ? "+" : ""}${changePct.toFixed(2)}%</em>`
                  : "";
              return `<div class="market-item"><span>${label}</span><strong>${formatted}/oz</strong>${delta}</div>`;
            })
            .join("");
        })
        .catch((error) => {
          const message = error instanceof Error ? error.message : "Live prices unavailable";
          renderFallback(message);
        });
    }
  }
</script>
